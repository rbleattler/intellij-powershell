{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "branch",
  "packageRules": [
    {
      "enabled": false,
      "description": "Kotlin is managed by intellij-updater.",
      "matchPackageNames": [
        "/org.jetbrains.kotlin.jvm/"
      ]
    },
    {
      "enabled": false,
      "description": "Custom Ivy dependencies are not published as Maven packages.",
      "matchPackageNames": [
        "PSScriptAnalyzer:PSScriptAnalyzer",
        "PowerShellEditorServices:PowerShellEditorServices"
      ]
    }
  ],
  "customManagers": [
    {
      "description": "Update the GitHub Actions runners.",
      "customType": "regex",
      "managerFilePatterns": [
        ".github/workflows/*.yml",
        "scripts/github-actions.fsx"
      ],
      "matchStrings": [
        "(?<depName>macos|ubuntu|windows)-(?<currentValue>[-\\w.\\d]+)"
      ],
      "datasourceTemplate": "github-runners"
    }
  ]
}
